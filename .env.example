# Client-safe (Expo public — bundled in app)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_LIVEKIT_URL=wss://your-livekit.livekit.cloud

# Server-only — NEVER in mobile bundle
SUPABASE_SERVICE_ROLE_KEY=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Supabase Edge Function secrets (Dashboard → Edge Functions → Secrets)
FIREBASE_SERVICE_ACCOUNT_JSON=
PUSH_WEBHOOK_SECRET=
# Random token for cron HTTP auth (evaluate-seller-levels, expire-stories)
CRON_SECRET=

# Optional Phase 2+
EXPO_PUBLIC_GIPHY_API_KEY=
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_PRIVACY_URL=https://nexio.app/privacy
EXPO_PUBLIC_TERMS_URL=https://nexio.app/terms
